{
    "ConnectionMode": "DevCS",
    "ConnectionStrings": {
        "ProdCS": "",
        "DevCS": "",
        "RedisConnectionString": ""
    },
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",
            "Microsoft.EntityFrameworkCore": "Warning"
        }
    },
    "Serilog": {
        "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "System": "Warning",
                "Hangfire": "Warning"
            }
        },
        "WriteTo": [
            {
                "Name": "Console"
            },
            {
                "Name": "File",
                "Args": {
                    "path": "Logs/applog-.txt",
                    "rollingInterval": "Day",
                    "rollOnFileSizeLimit": true,
                    "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
                }
            }
        ],
        "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
        "Properties": {
            "ApplicationName": "Planora"
        }
    },
    "JwtSettings": {
        "SecretKey": "",
        "Issuer": "Planora",
        "Audience": "Planora",
        "AccessTokenExpirationMinutes": 15,
        "RefreshTokenExpirationDays": 30
    },
    "EmailSettings": {
        "SenderEmail": "planora.ayair@gmail.com",
        "SenderName": "Planora",
        "SmtpHost": "smtp.gmail.com",
        "SmtpPort": 587,
        "Username": "planora.ayair@gmail.com",
        "Password": "",
        "UseSsl": true
    },
    "CacheOptions": {
        "Enabled": true,
        "MaximumKeyLength": 1024,
        "MaximumPayloadBytes": 1048576,
        "DefaultExpiration": "00:05:00",
        "DefaultLocalCacheExpiration": "00:05:00"
    },
    "AllowedHosts": "*"
}
